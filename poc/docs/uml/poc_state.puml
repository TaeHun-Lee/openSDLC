@startuml poc_state
title OpenSDLC PoC вҖ” PipelineState мғҒнғң лӢӨмқҙм–ҙк·ёлһЁ

skinparam backgroundColor #FAFAFA
skinparam state {
  BackgroundColor #EBF5FB
  BorderColor #2980B9
  ArrowColor #2C3E50
  StartColor #2C3E50
  EndColor #2C3E50
}

[*] --> Initialized : run_pipeline() нҳём¶ң

state Initialized {
  : user_story = мһ…л Ҙк°’
  : steps_completed = []
  : latest_artifacts = {}
  : iteration_count = 0
  : pipeline_status = "running"
}

Initialized --> Requirements : LangGraph.invoke()

state Requirements {
  state "ReqAgent мӢӨн–үмӨ‘" as req_running {
    : LLM лҸ…лҰҪ нҳём¶ң
    : UseCaseModelArtifact мғқм„ұ
    : latest_artifacts к°ұмӢ 
  }

  state "ValidatorAgent мӢӨн–үмӨ‘" as val_req {
    : UC artifactл§Ң мһ…л Ҙ
    : ValidationReport мғқм„ұ
    : validation_result м¶”м¶ң
  }

  req_running --> val_req
}

state ValidationCheck_UC <<choice>>
Requirements --> ValidationCheck_UC

ValidationCheck_UC --> TestDesign : pass
ValidationCheck_UC --> Requirements : fail\n(iteration_count < max)
ValidationCheck_UC --> Failed : fail\n(iteration_count >= max)

state TestDesign {
  state "TestAgent мӢӨн–үмӨ‘\n(mode=design)" as test_design {
    : UC artifact мһ…л Ҙ
    : TestDesignArtifact мғқм„ұ
  }
  state "ValidatorAgent мӢӨн–үмӨ‘" as val_test {
    : TestDesign artifact кІҖмҰқ
  }
  test_design --> val_test
}

state ValidationCheck_TD <<choice>>
TestDesign --> ValidationCheck_TD

ValidationCheck_TD --> Implementation : pass
ValidationCheck_TD --> TestDesign : fail (мһ¬мһ‘м—…)
ValidationCheck_TD --> Failed : н•ңкі„ мҙҲкіј

state Implementation {
  state "CodeAgent мӢӨн–үмӨ‘" as code {
    : UC + TestDesign artifact мһ…л Ҙ
    : ImplementationArtifact мғқм„ұ
    : (YAML + мӢӨм ң мҪ”л“ң нҸ¬н•Ё)
  }
  state "ValidatorAgent мӢӨн–үмӨ‘" as val_impl {
    : Implementation artifact кІҖмҰқ
  }
  code --> val_impl
}

state ValidationCheck_IMPL <<choice>>
Implementation --> ValidationCheck_IMPL

ValidationCheck_IMPL --> TestExecution : pass
ValidationCheck_IMPL --> Implementation : fail (мһ¬мһ‘м—…)
ValidationCheck_IMPL --> Failed : н•ңкі„ мҙҲкіј

state TestExecution {
  state "TestAgent мӢӨн–үмӨ‘\n(mode=execution)" as test_exec {
    : TestDesign + Impl artifact мһ…л Ҙ
    : TestReportArtifact мғқм„ұ
  }
  state "ValidatorAgent мӢӨн–үмӨ‘" as val_test_exec {
    : TestReport artifact кІҖмҰқ
  }
  test_exec --> val_test_exec
}

state ValidationCheck_TR <<choice>>
TestExecution --> ValidationCheck_TR

ValidationCheck_TR --> Feedback : pass
ValidationCheck_TR --> TestExecution : fail (мһ¬мһ‘м—…)
ValidationCheck_TR --> Failed : н•ңкі„ мҙҲкіј

state Feedback {
  state "CoordAgent мӢӨн–үмӨ‘" as coord {
    : TestReport artifact мһ…л Ҙ
    : FeedbackArtifact мғқм„ұ
  }
}

Feedback --> Saving

state Saving {
  : steps_completed вҶ’ iterationлі„ к·ёлЈ№нҷ”
  : output/iteration-N/artifacts/*.yaml м ҖмһҘ
  : output/workspace/ мҪ”л“ң нҢҢмқј м ҖмһҘ
  : pipeline_status = "completed"
}

state Failed {
  : pipeline_status = "max_retries_exceeded"
}

Saving --> [*] : мҷ„лЈҢ
Failed --> [*] : л№„м •мғҒ мў…лЈҢ

note right of Requirements
  **Context кІ©лҰ¬ мӣҗм№ҷ**:
  ValidatorAgentм—җкІҢлҠ”
  artifact YAMLл§Ң м „лӢ¬.
  мқҙм „ Agentмқҳ мӮ¬кі  кіјм •,
  system_prompt лҜёнҸ¬н•Ё.
end note

note right of Saving
  **мӮ°м¶ңл¬ј кө¬мЎ°**:
  output/
  в”ңв”Җв”Җ iteration-01/artifacts/
  в”Ӯ   в”ңв”Җв”Җ 001_UC-01.yaml
  в”Ӯ   в”ңв”Җв”Җ 002_UC-01-VAL-1.yaml
  в”Ӯ   в””в”Җв”Җ ...
  в””в”Җв”Җ workspace/
      в””в”Җв”Җ (мӢӨн–ү к°ҖлҠҘн•ң мҪ”л“ң)
end note

@enduml
